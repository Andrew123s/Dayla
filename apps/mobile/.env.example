# ── Dayla Mobile — Environment Variables ──────────────────────────────────────
#
# Copy this file to .env  (cp .env.example .env)
#
# `npm start` (start-expo-lan.cjs) auto-writes EXPO_PUBLIC_API_URL with your
# machine's LAN IP each run, so you typically don't need to edit this manually.
#
# Physical device rules:
#   - Use your PC's LAN IP (e.g. 192.168.1.42) — NOT "localhost" / "127.0.0.1"
#   - Device and PC must be on the SAME WiFi network
#   - Android emulator only: use 10.0.2.2 instead of the LAN IP
#   - iOS Simulator only: 127.0.0.1 / localhost works
# ──────────────────────────────────────────────────────────────────────────────

# Auto-set by start script. Override here for a static value.
EXPO_PUBLIC_API_URL=http://192.168.x.x:3005
