{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./*"],
      "@dayla/types": ["../../packages/types/src"],
      "@dayla/config": ["../../packages/config/src"],
      "@dayla/auth": ["../../packages/auth/src"],
      "@dayla/api": ["../../packages/api/src"],
      "@dayla/socket": ["../../packages/socket/src"],
      "@dayla/utils": ["../../packages/utils/src"]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": [
    ".",
    "../../packages/*/src"
  ]
}
