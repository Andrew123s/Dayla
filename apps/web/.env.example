# Web app build-time env (Vite). Copy to .env for local dev; set the same vars in
# Netlify → Site configuration → Environment variables for the deployed build.
#
# VITE_ vars are BAKED INTO THE BUNDLE AT BUILD TIME — a repo .env is git-ignored
# and never reaches Netlify, so the map key MUST be set in Netlify's env for
# daylapp.com to load tiles.

# MapTiler tile key (Piko trail maps). Client key — protect it by locking it to
# your domains in the MapTiler dashboard (Allowed origins), not by hiding it.
VITE_MAPTILER_KEY="your_maptiler_key"

# Optional full style-URL override (self-hosted / Stadia / Protomaps).
# VITE_MAP_STYLE_URL="https://.../style.json"

# API base (blank = same origin; set to the backend URL if the API is elsewhere).
# VITE_API_URL="https://your-api-host"
