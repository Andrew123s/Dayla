{
  "name": "dayla",
  "private": true,
  "scripts": {
    "dev:web": "pnpm --filter @dayla/web dev",
    "dev:mobile": "pnpm --filter @dayla/mobile start",
    "dev:backend": "pnpm --filter @dayla/backend dev",
    "build:web": "pnpm --filter @dayla/web build",
    "build:packages": "turbo run build --filter='./packages/*'",
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "~5.8.2"
  },
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=18.0.0"
  }
}
